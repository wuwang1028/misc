import time
import os
import socket
from ftplib import FTP

# 判断匿名ftp登录是否成功
def check_anonymous_ftp(host):
    try:
        ftp = FTP()
        ftp.connect(host)
        ftp.login()  # 尝试匿名登录
        ftp.quit()
        return True
    except Exception as e:
        return False

# 0表示修复失败，1表示修复成功
def check():
    s=socket.socket()
    ip = "127.0.0.1"
    port = 6379
    s = socket.socket(socket.AF_INET,socket.SOCK_STREAM)
    s.connect((ip, port))
    s.send(bytes(f"auth aaaaaaaaaaaaaaaaaaaaaaaaaaaaa \n", encoding="utf-8"))
    result = s.recv(1024)
    if b"called without any password configured for the default user" in result:
        s.close()
        return 0
    elif b"WRONGPASS" in result:
        s.close()
        # 再判断ftp匿名登录
        if check_anonymous_ftp("127.0.0.1"):
            return 0
        else:
            return 1
    else:
        return 0

if __name__ == "__main__":
    while True:
        time.sleep(15)
        if check() == 1:
            flag = os.popen("/readflag").read()
            with open("/flag", 'w') as f:
                f.write(f'{flag}')
                f.close()
            os.popen("chmod 777 /flag")
